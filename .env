#----------------------- Backend Config ------------------------------#
DATABASE_URL=postgresql://postgres:testpass@hoppscotch-db:5432/hoppscotch

# Sensitive Data Encryption Key (must be exactly 32 characters)
DATA_ENCRYPTION_KEY=change_me_to_a_32_char_key_here!

# Origins allowed to interact with the app (update if using a custom domain)
WHITELISTED_ORIGINS=http://localhost:3170,http://localhost:3000,http://localhost:3100,app://localhost_3200,app://hoppscotch

TRUST_PROXY=false

#----------------------- Mailer Config (Mailpit) ---------------------#
MAILER_SMTP_ENABLE=true
MAILER_USE_CUSTOM_CONFIGS=true
MAILER_ADDRESS_FROM="Hoppscotch <no-reply@hoppscotch.local>"
MAILER_SMTP_HOST=mailpit
MAILER_SMTP_PORT=1025
MAILER_SMTP_SECURE=false
MAILER_SMTP_USER=
MAILER_SMTP_PASSWORD=

#----------------------- Frontend Config -----------------------------#
VITE_BASE_URL=http://localhost:3000
VITE_SHORTCODE_BASE_URL=http://localhost:3000
VITE_ADMIN_URL=http://localhost:3100

VITE_BACKEND_GQL_URL=http://localhost:3170/graphql
VITE_BACKEND_WS_URL=ws://localhost:3170/graphql
VITE_BACKEND_API_URL=http://localhost:3170/v1

# Enable email as an auth provider
VITE_ALLOWED_AUTH_PROVIDERS=EMAIL

VITE_APP_TOS_LINK=https://docs.hoppscotch.io/support/terms
VITE_APP_PRIVACY_POLICY_LINK=https://docs.hoppscotch.io/support/privacy

VITE_PROXYSCOTCH_ACCESS_TOKEN=
ENABLE_SUBPATH_BASED_ACCESS=false
